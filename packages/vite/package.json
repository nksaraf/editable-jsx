{
  "name": "@editable-jsx/vite",
  "author": {
    "name": "Nikhil Saraf",
    "email": "nsaraf98@gmail.com",
    "url": "https://github.com/nksaraf"
  },
  "description": "Vite plugin for editable JSX — in-screen visual editor for React apps",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "import": "./dist/client.js"
    },
    "./editor": {
      "import": "./dist/editor.js"
    }
  },
  "files": [
    "dist/**",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "bun test"
  },
  "dependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@editable-jsx/babel": "workspace:*",
    "@editable-jsx/editable": "workspace:*",
    "@editable-jsx/state": "workspace:*",
    "@rolldown/plugin-babel": "^0.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "formidable": "^2.1.1",
    "fast-glob": "^3.3.0",
    "ts-morph": "^25.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.0",
    "@types/formidable": "^2.0.5"
  }
}
