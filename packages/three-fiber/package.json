{
  "name": "@react-three/editor",
  "author": {
    "name": "Nikhil Saraf",
    "email": "nsaraf98@gmail.com",
    "url": "https://github.com/nksaraf"
  },
  "description": "React Three Fiber editor integration",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fiber": {
      "types": "./dist/fiber.d.ts",
      "import": "./dist/fiber.js",
      "require": "./dist/fiber.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    }
  },
  "files": [
    "dist/**",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@editable-jsx/commander": "workspace:*",
    "@editable-jsx/editable": "workspace:*",
    "@editable-jsx/panels": "workspace:*",
    "@editable-jsx/state": "workspace:*",
    "@editable-jsx/ui": "workspace:*",
    "@editable-jsx/vite": "workspace:*",
    "its-fine": "^1.0.8",
    "suspend-react": "^0.0.8",
    "hash-sum": "^2.0.0",
    "leva": "^0.9.34",
    "zustand": "^3.7.2"
  },
  "peerDependencies": {
    "@react-three/fiber": "*",
    "@react-three/drei": "*",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "three": "*"
  }
}
