{
  "name": "@editable-jsx/css",
  "author": {
    "name": "Nikhil Saraf",
    "email": "nsaraf98@gmail.com",
    "url": "https://github.com/nksaraf"
  },
  "description": "Framework-agnostic CSS visual editor — edit CSS variables, styles, and text content in any Vite project",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "import": "./dist/client.js"
    },
    "./editor": {
      "import": "./dist/editor.js"
    }
  },
  "files": [
    "dist/**",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "bun test"
  },
  "dependencies": {
    "postcss": "^8.5.0",
    "fast-glob": "^3.3.0"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vite": "^6.0.0"
  }
}
