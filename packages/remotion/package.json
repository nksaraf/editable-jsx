{
  "name": "@editable-jsx/remotion",
  "author": {
    "name": "Nikhil Saraf",
    "email": "nsaraf98@gmail.com",
    "url": "https://github.com/nksaraf"
  },
  "description": "Remotion integration for editable JSX",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@editable-jsx/commander": "workspace:*",
    "@editable-jsx/editable": "workspace:*",
    "@editable-jsx/panels": "workspace:*",
    "@editable-jsx/state": "workspace:*",
    "@editable-jsx/ui": "workspace:*",
    "@editable-jsx/vite": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@remotion/player": "*",
    "@remotion/three": "*"
  }
}
