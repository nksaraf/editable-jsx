{
  "name": "@editable-jsx/babel",
  "author": {
    "name": "Nikhil Saraf",
    "email": "nsaraf98@gmail.com",
    "url": "https://github.com/nksaraf"
  },
  "description": "Babel plugin for editable JSX — instruments React components with source metadata",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "bun test"
  },
  "dependencies": {
    "@babel/core": "^7.26.0",
    "@babel/template": "^7.26.0",
    "@babel/helper-plugin-utils": "^7.26.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.0",
    "@types/babel__helper-plugin-utils": "^7.10.0",
    "@types/babel__template": "^7.4.4"
  }
}
